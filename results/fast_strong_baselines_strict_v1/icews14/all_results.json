      "lambda_ood": 0.001,
      "lr": 0.0007,
      "meta_lr": 0.01,
      "meta_query_size": 16,
      "meta_support_size": 16,
      "negative_mode_eval": "filtered",
      "negative_mode_train": "filtered",
      "num_neg_eval": 25,
      "num_neg_train": 1,
      "patience": 5,
      "weight_decay": 0.0001
    }
  },
