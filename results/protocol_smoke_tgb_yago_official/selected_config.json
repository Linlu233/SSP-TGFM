{
  "ablation": {
    "enabled": false
  },
  "baselines": [],
  "data": {
    "download": false,
    "format": "tgb",
    "name": "tkgl-yago",
    "root": "/root/autodl-tmp/data/data/raw/tgb"
  },
  "device": "cuda",
  "eval": {
    "filtered_rank_edges": 1,
    "tgb_eval_edges": 1,
    "tgb_official": true,
    "tgb_val_edges": 1
  },
  "few_shot_ratios": [
    1.0
  ],
  "model": {
    "adapter_rank": 16,
    "hidden_dim": 128,
    "prompt_heads": 4,
    "prompt_tokens": 4,
    "relation_rank": 16,
    "temporal_encoder": "mlp",
    "temporal_layers": 1,
    "time_dim": 32,
    "time_encoder": "fourier",
    "use_cross": true,
    "use_gate": true,
    "use_sem": true,
    "use_struct": true,
    "use_variational": true
  },
  "output_dir": "results/protocol_smoke_tgb_yago_official",
  "require_cuda": true,
  "seeds": [
    1
  ],
  "split": {
    "mode": "labels"
  },
  "strict_full_formula": true,
  "text": {
    "backend": "hashing",
    "cache_dir": "data/processed/text_cache",
    "dim": 384
  },
  "train": {
    "align_temperature": 0.2,
    "batch_size": 256,
    "early_stop_metric": "val_tgb_mrr",
    "early_stop_weights": {
      "val_ap": 0.05,
      "val_auc": 0.05,
      "val_hits@10": 0.1,
      "val_mrr": 0.7,
      "val_ndcg": 0.1
    },
    "epochs": 1,
    "filter_scope": "exact",
    "grad_clip": 1.0,
    "lambda_align": 0.01,
    "lambda_kl": 0.0001,
    "lambda_meta": 0.005,
    "lambda_ood": 0.001,
    "lr": 0.0007,
    "meta_lr": 0.01,
    "meta_query_size": 4,
    "meta_support_size": 4,
    "negative_mode_eval": "filtered",
    "negative_mode_train": "filtered",
    "num_neg_eval": 3,
    "num_neg_train": 5,
    "patience": 1,
    "progress_every_batches": 100,
    "progress_every_seconds": 120.0,
    "val_binary_edges": 32,
    "val_rank_edges": 0,
    "weight_decay": 0.0001
  }
}