{
  "ablation": {
    "enabled": false
  },
  "baselines": [],
  "data": {
    "name": "synthetic",
    "num_edges": 1600,
    "num_nodes": 256,
    "num_relations": 4,
    "num_topics": 8,
    "seed": 1
  },
  "device": "cuda",
  "eval": {
    "filtered_rank_edges": 100
  },
  "few_shot_ratios": [
    1.0
  ],
  "model": {
    "adapter_rank": 20,
    "hidden_dim": 160,
    "prompt_heads": 4,
    "prompt_tokens": 4,
    "relation_rank": 20,
    "temporal_encoder": "mlp",
    "temporal_layers": 2,
    "time_dim": 32,
    "time_encoder": "fourier",
    "use_cross": true,
    "use_gate": true,
    "use_sem": true,
    "use_struct": true,
    "use_variational": true
  },
  "output_dir": "results/ssptgfm_search_synthetic_stronggate_v5",
  "require_cuda": true,
  "scenario": {
    "name": "standard"
  },
  "seeds": [
    1,
    2,
    3
  ],
  "split": {
    "test_ratio": 0.15,
    "val_ratio": 0.15
  },
  "strict_full_formula": true,
  "text": {
    "backend": "hashing",
    "cache_dir": "data/processed/text_cache",
    "dim": 384
  },
  "train": {
    "align_temperature": 0.2,
    "batch_size": 256,
    "early_stop_metric": "composite",
    "early_stop_minima": {
      "val_ap": 0.215,
      "val_auc": 0.865,
      "val_hits@10": 0.28,
      "val_mrr": 0.13
    },
    "early_stop_weights": {
      "val_ap": 0.55,
      "val_auc": 0.55,
      "val_hits@10": 0.85,
      "val_mrr": 2.2,
      "val_ndcg": 0.2
    },
    "epochs": 18,
    "filter_scope": "exact",
    "grad_clip": 1.0,
    "lambda_align": 0.0001,
    "lambda_kl": 1e-06,
    "lambda_meta": 0.005,
    "lambda_ood": 0.001,
    "lr": 0.0008,
    "meta_lr": 0.01,
    "meta_query_size": 16,
    "meta_support_size": 16,
    "negative_mode_eval": "filtered",
    "negative_mode_train": "filtered",
    "num_neg_eval": 25,
    "num_neg_train": 4,
    "patience": 5,
    "progress_every_seconds": 120,
    "val_rank_edges": 100,
    "weight_decay": 0.0001
  }
}