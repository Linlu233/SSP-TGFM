{
  "ablation": {
    "enabled": false
  },
  "baselines": [],
  "data": {
    "format": "csv",
    "name": "yago15k-temporal",
    "path": "data/raw/yago15k_temporal"
  },
  "device": "cuda",
  "eval": {
    "filtered_rank_edges": 150
  },
  "few_shot_ratios": [
    1.0
  ],
  "model": {
    "adapter_rank": 16,
    "freeze_history_prior": true,
    "hidden_dim": 128,
    "history_prior_init_scale": 1.5,
    "history_prior_mode": "linear",
    "prompt_heads": 4,
    "prompt_tokens": 4,
    "relation_rank": 16,
    "struct_feature_init_scale": 0.2,
    "temporal_encoder": "mlp",
    "temporal_layers": 1,
    "time_dim": 32,
    "time_encoder": "fourier",
    "use_cross": true,
    "use_gate": true,
    "use_history_prior": true,
    "use_sem": true,
    "use_struct": true,
    "use_struct_feature_residual": true,
    "use_variational": true
  },
  "output_dir": "results/unified_s15_fe647b370ebb_val/search_yago15k_temporal",
  "require_cuda": true,
  "seeds": [
    1
  ],
  "split": {
    "mode": "time",
    "test_ratio": 0.15,
    "val_ratio": 0.15
  },
  "strict_full_formula": true,
  "text": {
    "backend": "hashing",
    "cache_dir": "data/processed/text_cache",
    "dim": 384
  },
  "train": {
    "align_temperature": 0.2,
    "batch_size": 512,
    "candidate_rank_queries": 64,
    "candidate_rank_sides": "both",
    "candidate_rank_size": 64,
    "early_stop_metric": "val_composite",
    "early_stop_weights": {
      "val_ap": 0.15,
      "val_auc": 0.05,
      "val_hits@10": 0.2,
      "val_mrr": 0.5,
      "val_ndcg": 0.1
    },
    "epochs": 10,
    "eval_batch_size_candidates": 512,
    "filter_scope": "exact",
    "grad_clip": 1.0,
    "lambda_align": 0.01,
    "lambda_candidate_rank": 0.05,
    "lambda_kl": 0.0001,
    "lambda_meta": 0.005,
    "lambda_ood": 0.001,
    "lambda_rank": 0.01,
    "lr": 0.0007,
    "meta_lr": 0.01,
    "meta_query_size": 8,
    "meta_support_size": 8,
    "negative_mode_eval": "filtered",
    "negative_mode_train": "relation_hard",
    "num_neg_eval": 10,
    "num_neg_train": 1,
    "patience": 3,
    "rank_loss_type": "bpr",
    "rank_margin": 0.0,
    "val_binary_edges": 512,
    "val_eval_sample": "temporal_uniform",
    "val_rank_edges": 150,
    "weight_decay": 0.0001
  }
}